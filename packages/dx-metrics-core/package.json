{
  "name": "@pagopa/dx-metrics-core",
  "version": "0.1.3",
  "type": "module",
  "private": true,
  "description": "Shared configuration and database contracts for DX Metrics apps.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./config": {
      "types": "./src/config.ts",
      "import": "./src/config.ts"
    },
    "./database": {
      "types": "./src/database.ts",
      "import": "./src/database.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "import": "./src/schema.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@pagopa/eslint-config": "workspace:^",
    "@tsconfig/node24": "catalog:",
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.30.6",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
