{
  "name": "@pagopa/dx-savemoney",
  "version": "0.5.0",
  "type": "module",
  "description": "Azure resource analyzer for finding unused or cost-inefficient resources.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pagopa/dx.git",
    "directory": "packages/savemoney"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "tsc --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "azure",
    "typescript",
    "finops",
    "DX"
  ],
  "dependencies": {
    "@azure/arm-advisor": "^3.2.0",
    "@azure/arm-appcontainers": "^3.0.0",
    "@azure/arm-appservice": "^17.0.0",
    "@azure/arm-compute": "^23.3.0",
    "@azure/arm-monitor": "^7.0.0",
    "@azure/arm-network": "^34.2.0",
    "@azure/arm-resources": "catalog:azure",
    "@azure/identity": "catalog:",
    "@logtape/logtape": "catalog:",
    "cli-table3": "^0.6.5",
    "js-yaml": "catalog:",
    "p-limit": "^7.3.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@pagopa/eslint-config": "workspace:^",
    "@tsconfig/node24": "catalog:",
    "@types/js-yaml": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
