{
  "name": "@pagopa/azure-tracing",
  "version": "0.5.5",
  "type": "module",
  "description": "A package that contains some utilities to enable Azure tracing on Node.js applications.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pagopa/dx.git",
    "directory": "packages/azure-tracing"
  },
  "nx": {
    "targets": {
      "integration": {
        "executor": "nx:run-commands",
        "cache": false,
        "dependsOn": [
          "^build"
        ],
        "options": {
          "command": "pnpm run integration",
          "cwd": "packages/azure-tracing"
        }
      }
    }
  },
  "keywords": [
    "azure",
    "azuremonitor",
    "opentelemetry"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/functions/index.js",
  "exports": {
    ".": {
      "types": "./dist/functions/index.d.ts",
      "import": "./dist/functions/index.js",
      "require": "./dist/functions/index.cjs"
    },
    "./logger": {
      "types": "./dist/opentelemetry/logger.d.ts",
      "import": "./dist/opentelemetry/logger.js",
      "require": "./dist/opentelemetry/logger.cjs"
    },
    "./azure-monitor": {
      "types": "./dist/monitor/index.d.ts",
      "import": "./dist/monitor/index.js",
      "require": "./dist/monitor/index.cjs"
    },
    "./azure-functions": {
      "types": "./dist/functions/hooks.d.ts",
      "import": "./dist/functions/hooks.js",
      "require": "./dist/functions/hooks.cjs"
    },
    "./azure-functions/v3": {
      "types": "./dist/functions/v3/index.d.ts",
      "import": "./dist/functions/v3/index.js",
      "require": "./dist/functions/v3/index.cjs"
    }
  },
  "types": "./dist/functions/index.d.ts",
  "typesVersions": {
    "*": {
      "azure-functions": [
        "dist/functions/hooks.d.ts"
      ],
      "azure-functions/v3": [
        "dist/functions/v3/index.d.ts"
      ],
      "logger": [
        "dist/opentelemetry/logger.d.ts"
      ],
      "azure-monitor": [
        "dist/monitor/index.d.ts"
      ],
      "*": [
        "dist/*"
      ]
    }
  },
  "dependencies": {
    "@azure/identity": "catalog:",
    "@azure/monitor-opentelemetry": "catalog:opentelemetry",
    "@azure/monitor-opentelemetry-exporter": "catalog:opentelemetry",
    "@opentelemetry/api": "catalog:opentelemetry",
    "@opentelemetry/api-logs": "catalog:opentelemetry",
    "@opentelemetry/instrumentation": "catalog:opentelemetry",
    "@opentelemetry/instrumentation-undici": "catalog:opentelemetry",
    "@t3-oss/env-core": "^0.13.11",
    "import-in-the-middle": "^3.3.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@azure/cosmos": "^4.9.3",
    "@azure/functions": "^4.16.1",
    "@azure/storage-blob": "catalog:azure",
    "@pagopa/eslint-config": "workspace:^",
    "@tsconfig/node24": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "redis": "^5.12.1",
    "testcontainers": "^12.0.4",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "scripts": {
    "build": "tsup",
    "test:integration": "vitest run --config vitest.integration.config.js"
  }
}
