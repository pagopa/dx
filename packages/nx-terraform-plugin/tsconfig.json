{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    "isolatedModules": true,
    "declaration": true,
    "importHelpers": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ES2023", "ES2024.Object", "ESNext.Collection"],
    "target": "ES2023",
    "customConditions": ["@nx/source"],
    "rewriteRelativeImportExtensions": true
  },
  "include": ["src/**/*.ts"]
}
