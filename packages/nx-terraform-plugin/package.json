{
  "name": "@pagopa/nx-terraform-plugin",
  "version": "0.3.2",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@nx/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./release/version-actions": {
      "@nx/source": "./src/release/version-actions.ts",
      "types": "./dist/release/version-actions.d.ts",
      "import": "./dist/release/version-actions.js",
      "require": "./src/release/version-actions.ts",
      "default": "./dist/release/version-actions.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pagopa/dx.git",
    "directory": "packages/nx-terraform-plugin"
  },
  "scripts": {
    "generate": "node src/generate-module-schema.ts"
  },
  "devDependencies": {
    "@pagopa/eslint-config": "workspace:^",
    "@tsconfig/node24": "catalog:",
    "@types/node": "catalog:",
    "@types/semver": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@logtape/logtape": "catalog:",
    "@nx/devkit": "^22.7.1",
    "execa": "catalog:",
    "octokit": "catalog:",
    "semver": "catalog:",
    "tslib": "^2.8.1",
    "zod": "catalog:"
  },
  "executors": "./executors.json"
}
