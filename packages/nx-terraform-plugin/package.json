{
  "name": "@pagopa/nx-terraform-plugin",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./release/version-actions": {
      "types": "./dist/release/version-actions.d.ts",
      "import": "./dist/release/version-actions.js",
      "require": "./src/release/version-actions.ts",
      "default": "./dist/release/version-actions.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pagopa/dx.git",
    "directory": "packages/nx-terraform-plugin"
  },
  "scripts": {
    "build": "tsdown",
    "generate": "node src/generate-module-schema.ts"
  },
  "devDependencies": {
    "@pagopa/dx-tasks": "workspace:^",
    "@pagopa/eslint-config": "workspace:^",
    "@tsconfig/node24": "catalog:",
    "@types/node": "catalog:",
    "@types/semver": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "catalog:aws",
    "@azure/identity": "catalog:",
    "@azure/storage-blob": "catalog:azure",
    "@logtape/logtape": "catalog:",
    "@nx/devkit": "^22.7.6",
    "@octokit/auth-app": "^8.2.0",
    "execa": "catalog:",
    "octokit": "catalog:",
    "semver": "catalog:",
    "tslib": "^2.8.1",
    "zod": "catalog:"
  },
  "executors": "./executors.json",
  "nx": {
    "targets": {
      "build": {
        "inputs": [
          "default",
          "^default"
        ],
        "outputs": [
          "{projectRoot}/dist/**"
        ]
      }
    }
  }
}
