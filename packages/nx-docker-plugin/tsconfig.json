{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    "isolatedModules": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ES2023", "ES2024.Object", "ESNext.Collection"],
    "target": "ES2023",
    "types": ["node"],
    "customConditions": ["@nx/source"],
    "rewriteRelativeImportExtensions": true
  },
  "include": ["./src/**/*.ts"]
}