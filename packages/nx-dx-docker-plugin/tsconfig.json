{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    "isolatedModules": true,
    "declaration": true,
    "importHelpers": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "rewriteRelativeImportExtensions": true,
    "types": ["node"],
    "emitDeclarationOnly": true
  },
  "include": ["./src/**/*.ts"]
}
