{
  "name": "@pagopa/nx-dx-docker-plugin",
  "version": "0.1.0",
  "description": "Nx plugin generating Docker build/push/package targets, feature-matching docker/metadata-action.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pagopa/dx.git",
    "directory": "packages/nx-dx-docker-plugin"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "tsdown"
  },
  "devDependencies": {
    "@pagopa/eslint-config": "workspace:^",
    "@tsconfig/node24": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@nx/devkit": "^22.7.6",
    "tslib": "^2.8.1",
    "zod": "catalog:"
  },
  "nx": {
    "targets": {
      "build": {
        "inputs": ["default", "^default"],
        "outputs": ["{projectRoot}/dist/**"]
      }
    }
  }
}

