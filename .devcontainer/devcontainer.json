{
  "image": "mcr.microsoft.com/devcontainers/base:debian@sha256:a30da48cdf5f9144ff7f2156622e701e752fc258d77ca7bb00120624f1a95938",
  "features": {
    "ghcr.io/devcontainers-extra/features/pre-commit:2": {},
    "ghcr.io/pagopa/devcontainer-features/acli:1": {},
    "ghcr.io/devcontainers/features/azure-cli:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {
      "extensions": ["seachicken/gh-poi"]
    },
    "ghcr.io/devcontainers/features/terraform:1": {
      "version": "latest",
      "tflint": "latest",
      "installTFsec": true,
      "installTerraformDocs": true
    },
    "ghcr.io/pagopa/devcontainer-features/trivy:1": {},
    "ghcr.io/devcontainers-extra/features/syft:1": {},
    "ghcr.io/devcontainers-extra/features/grype:1": {},
    "ghcr.io/pagopa/devcontainer-features/plantuml:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24",
      "installYarnUsingApt": false,
      "pnpmVersion": "none",
      "nvmInstallPath": "/opt/nvm"
    },
    "ghcr.io/devcontainers/features/go:1": {},
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false
    },
    "ghcr.io/devcontainers-extra/features/act:1": {},
    "ghcr.io/pagopa/devcontainer-features/shellcheck:1": {},
    "ghcr.io/devcontainers-extra/features/nx-npm:1": {},
    "ghcr.io/devcontainers/features/aws-cli:1": {},
    "ghcr.io/devcontainers/features/copilot-cli:1": {}
  },
  "postCreateCommand": {
    "install-ripgrep": "sudo apt-get update && sudo apt-get install --no-install-recommends -y ripgrep",
    "alias-xdg-open": "echo 'alias xdg-open=\"code --openExternal\"' >> ~/.bashrc"
  },
  "postStartCommand": {
    "set-workspace-as-safe-dir": "git config --global --add safe.directory ${containerWorkspaceFolder}"
  },
  "containerEnv": {
    "COREPACK_ENABLE_DOWNLOAD_PROMPT": "0",
    "NX_DAEMON": "true",
    "EDITOR": "code --reuse-window --wait"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "-vscjava.vscode-java-pack",
        "-ms-dotnettools.csharp",
        "-ms-azuretools.vscode-azureterraform",
        "ms-azuretools.vscode-azure-github-copilot",
        "ms-vscode.vscode-websearchforcopilot",
        "ms-azuretools.vscode-azureterraform",
        "github.vscode-github-actions",
        "github.vscode-pull-request-github",
        "esbenp.prettier-vscode",
        "unifiedjs.vscode-mdx",
        "EditorConfig.EditorConfig",
        "bruno-api-client.bruno",
        "vitest.explorer",
        "redhat.vscode-yaml",
        "dbaeumer.vscode-eslint",
        "github.copilot",
        "github.copilot-chat",
        "nrwl.angular-console"
      ]
    }
  }
}
