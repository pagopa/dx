{
  "name": "dx-metrics-import",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "description": "DX Metrics importer that synchronizes GitHub engineering data into PostgreSQL.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pagopa/dx.git",
    "directory": "apps/dx-metrics-import"
  },
  "scripts": {
    "build": "esbuild src/import.ts --bundle --platform=node --format=esm --outfile=dist/import.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "import": "tsx src/import.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@octokit/auth-app": "^8.2.0",
    "@pagopa/dx-metrics-core": "workspace:*",
    "drizzle-orm": "^0.45.0",
    "js-yaml": "catalog:",
    "octokit": "^5.0.5",
    "terrawiz": "^1.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@pagopa/eslint-config": "workspace:^",
    "@types/js-yaml": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "esbuild": "^0.27.7",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
