{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DX Tooling Lifecycle Data",
  "description": "Schema for the DX tooling lifecycle status data used by the lifecycle page.",
  "type": "object",
  "required": ["tools"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/ToolLifecycle"
      }
    }
  },
  "$defs": {
    "ToolLifecycle": {
      "type": "object",
      "required": [
        "id",
        "name",
        "category",
        "communicationChannels",
        "lifecyclePolicy",
        "vendorLifecycleUrl",
        "versions"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the tool (e.g., 'nodejs', 'terraform')."
        },
        "name": {
          "type": "string",
          "description": "Display name of the tool."
        },
        "category": {
          "type": "string",
          "enum": ["runtime", "infra", "build-tool", "ci"],
          "description": "Tool category used for grouping and badge styling."
        },
        "communicationChannels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "description": "How lifecycle transitions are communicated to teams."
        },
        "lifecyclePolicy": {
          "type": "string",
          "description": "Human-readable description of the tool's lifecycle policy."
        },
        "vendorLifecycleUrl": {
          "type": "string",
          "pattern": "^(/|https?://)",
          "description": "URL to the vendor's lifecycle schedule or internal reference page. Use absolute URLs for external links or root-relative paths (e.g., '/docs/pipelines') for internal links."
        },
        "versions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/VersionEntry"
          }
        }
      }
    },
    "VersionEntry": {
      "type": "object",
      "required": ["version", "status"],
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "string",
          "description": "Version identifier (e.g., '22.x', '1.15.x', 'Provider: azurerm (~> 4.x)')."
        },
        "status": {
          "type": "string",
          "enum": ["active", "maintenance", "deprecated", "eol"],
          "description": "Current lifecycle status of this version."
        },
        "supportedSince": {
          "type": "string",
          "format": "date",
          "description": "Date (YYYY-MM-DD) when DX started supporting this version."
        },
        "eolDate": {
          "type": "string",
          "format": "date",
          "description": "Date (YYYY-MM-DD) when this version reaches End of Life."
        },
        "notes": {
          "type": "string",
          "description": "Additional context about this version's support status."
        },
        "migrationGuideUrl": {
          "type": "string",
          "format": "uri",
          "description": "URL to a migration guide for transitioning away from this version."
        }
      }
    }
  }
}
