{
  "name": "@pagopa-dx/terraform-plan-storage-download",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "description": "GitHub Action to download and extract a Terraform plan bundle from the state backend storage",
  "main": "dist/main.cjs",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@actions/core": "catalog:github-actions",
    "@aws-sdk/client-s3": "^3.808.0",
    "@azure/identity": "^4.10.0",
    "@azure/storage-blob": "^12.27.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@pagopa/eslint-config": "workspace:^",
    "@tsconfig/node24": "catalog:",
    "@types/node": "catalog:",
    "prettier": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
