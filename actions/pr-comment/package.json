{
  "name": "pr-comment-action",
  "version": "0.2.1",
  "type": "module",
  "private": true,
  "description": "TypeScript action for creating and managing PR comments",
  "main": "dist/index.cjs",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "github",
    "action",
    "pr",
    "comment",
    "typescript"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@actions/core": "catalog:github-actions",
    "@actions/github": "catalog:github-actions"
  },
  "devDependencies": {
    "@pagopa/eslint-config": "workspace:^",
    "@tsconfig/node24": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vitest-mock-extended": "catalog:"
  }
}
