{
  "name": "@pagopa-dx/terraform-plan-storage-upload",
  "version": "0.0.3",
  "type": "module",
  "private": true,
  "description": "GitHub Action to bundle and upload a Terraform plan to the state backend storage",
  "main": "dist/main.cjs",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@actions/core": "catalog:github-actions",
    "@aws-sdk/client-s3": "catalog:aws",
    "@azure/identity": "catalog:",
    "@azure/storage-blob": "catalog:azure",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@pagopa/eslint-config": "workspace:^",
    "@tsconfig/node24": "catalog:",
    "@types/node": "catalog:",
    "prettier": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
